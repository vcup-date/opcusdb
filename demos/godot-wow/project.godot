; opcusdb Townfall — Godot 4 client for the Rust town server (demos/server/src/wow.rs)
; Run the server:  cargo run -p opcusdb-server --bin opcusdb-wow
; Then open this folder in Godot 4.4+ and press Play (open two copies for multiplayer).

config_version=5

[application]

config/name="opcusdb Townfall"
run/main_scene="res://Main.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
